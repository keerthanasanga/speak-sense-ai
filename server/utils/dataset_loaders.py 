import os
import numpy as np
import librosa
import cv2
from tensorflow.keras.utils import to_categorical
import pandas as pd
from sklearn.model_selection import train_test_split

class RAVDESSLoader:
    """Loader for RAVDESS speech emotion dataset"""
    
    def __init__(self, data_path):
        self.data_path = data_path
        self.emotion_map = {
            '01': 'neutral',
            '02': 'calm',
            '03': 'happy',
            '04': 'sad',
            '05': 'angry',
            '06': 'fearful',
            '07': 'disgust',
            '08': 'surprised'
        }
        self.emotion_to_idx = {v: i for i, (k, v) in enumerate(self.emotion_map.items())}
        
    def load_data(self):
        """Load all audio files and extract features"""
        audio_data = []
        labels = []
        
        for file in os.listdir(self.data_path):
            if file.endswith('.wav'):
                # Parse filename (format: 03-01-06-01-02-01-12.wav)
                parts = file.split('-')
                if len(parts) >= 3:
                    emotion_code = parts[2]
                    emotion = self.emotion_map.get(emotion_code)
                    
                    if emotion:
                        # Load audio
                        file_path = os.path.join(self.data_path, file)
                        audio, sr = librosa.load(file_path, sr=22050)
                        
                        # Extract features
                        features = self.extract_features(audio, sr)
                        audio_data.append(features)
                        labels.append(self.emotion_to_idx[emotion])
        
        return np.array(audio_data), np.array(labels)
    
    def extract_features(self, audio, sr):
        """Extract MFCC features from audio"""
        # Extract MFCCs
        mfccs = librosa.feature.mfcc(y=audio, sr=sr, n_mfcc=40, n_fft=2048, hop_length=512)
        
        # Extract additional features
        chroma = librosa.feature.chroma_stft(y=audio, sr=sr)
        mel = librosa.feature.melspectrogram(y=audio, sr=sr)
        
        # Combine features
        features = np.vstack([mfccs, chroma, mel])
        
        # Pad/crop to fixed length
        target_length = 216  # Adjust based on your needs
        if features.shape[1] < target_length:
            # Pad
            pad_width = target_length - features.shape[1]
            features = np.pad(features, ((0, 0), (0, pad_width)), mode='constant')
        else:
            # Crop
            features = features[:, :target_length]
        
        return features.flatten()


class FER2013Loader:
    """Loader for FER2013 facial expression dataset"""
    
    def __init__(self, data_path):
        self.data_path = data_path
        self.emotions = ['angry', 'disgust', 'fear', 'happy', 'neutral', 'sad', 'surprise']
        self.img_size = (48, 48)
        
    def load_data_from_csv(self, csv_path):
        """Load from CSV format (original FER2013)"""
        df = pd.read_csv(csv_path)
        
        images = []
        labels = []
        
        for idx, row in df.iterrows():
            # Parse pixels
            pixels = np.array(row['pixels'].split(), dtype='float32')
            pixels = pixels.reshape(48, 48, 1) / 255.0  # Normalize
            
            images.append(pixels)
            labels.append(row['emotion'])
        
        return np.array(images), to_categorical(np.array(labels), num_classes=7)
    
    def load_data_from_folders(self, train_path, test_path):
        """Load from folder structure (cleaned version)"""
        def load_from_folder(folder_path):
            images = []
            labels = []
            
            for emotion_idx, emotion in enumerate(self.emotions):
                emotion_folder = os.path.join(folder_path, emotion)
                if os.path.exists(emotion_folder):
                    for img_file in os.listdir(emotion_folder):
                        if img_file.endswith(('.jpg', '.png')):
                            img_path = os.path.join(emotion_folder, img_file)
                            img = cv2.imread(img_path, cv2.IMREAD_GRAYSCALE)
                            img = cv2.resize(img, self.img_size)
                            img = img.reshape(48, 48, 1) / 255.0
                            
                            images.append(img)
                            labels.append(emotion_idx)
            
            return np.array(images), to_categorical(np.array(labels), num_classes=7)
        
        # Load train and test
        X_train, y_train = load_from_folder(train_path)
        X_test, y_test = load_from_folder(test_path)
        
        return (X_train, y_train), (X_test, y_test)
    
    def preprocess_for_live(self, frame):
        """Preprocess a live video frame for emotion prediction"""
        # Convert to grayscale
        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
        
        # Detect face (you'd use a face detector like Haar Cascade)
        face_cascade = cv2.CascadeClassifier(cv2.data.haarcascades + 'haarcascade_frontalface_default.xml')
        faces = face_cascade.detectMultiScale(gray, 1.3, 5)
        
        if len(faces) > 0:
            x, y, w, h = faces[0]
            face = gray[y:y+h, x:x+w]
            face = cv2.resize(face, self.img_size)
            face = face.reshape(1, 48, 48, 1) / 255.0
            return face
        
        return None