# ===========================
# SpeakSense AI  –  .gitignore
# ===========================

# ── Node / npm ──────────────────────────
node_modules/
client/node_modules/
server/node_modules/
ai-service/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# ── Build outputs ────────────────────────
build/
dist/
client/build/
server/dist/
.cache/

# ── Environment / secrets ────────────────
.env
.env.*
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
server/.env
client/.env
ai-service/.env
*.pem
*.key
*.secret

# ── Coverage / testing ───────────────────
coverage/
.nyc_output/
*.lcov
jest-results.json

# ── OS files ─────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Editor / IDE ─────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Python (ai-service) ──────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.ipynb_checkpoints/
venv/
env/
.venv/
ai-service/venv/
avatar-system/venv/
*venv*/
*_venv/
*.egg-info/
*.egg
*.whl
.Python

# ── Docker ───────────────────────────────
docker-compose.override.yml
.docker/

# ── Logs ─────────────────────────────────
logs/
*.log
*.pid
*.seed
*.pid.lock
server/logs/

# ── Runtime data ─────────────────────────
tmp/
temp/
.history/

# ── Datasets & Downloads ─────────────────
datasets/
*.crdownload

# ── Misc ─────────────────────────────────
*.tmp
*.bak
*.orig
.parcel-cache/
.eslintcache
.stylelintcache
.turbo/
storybook-static/

# ── Claude Code ───────────────────────────
.claude/projects/

# ── Local agent tooling ───────────────────
.local-tools/

# ── 3D Model caches ───────────────────────────────────
*.glb.cache
*.gltf.cache
draco/

# ── Lock files (keep one, ignore the rest) ────────────
package-lock.json
yarn.lock

# ── Uploads / user content ────────────────────────────
uploads/
public/uploads/
client/public/uploads/

# ── AI service extras ─────────────────────────────────
ai-service/__pycache__/
ai-service/models/
ai-service/checkpoints/

# ── Sensitive config ──────────────────────────────────
config/secrets.js
config/secrets.json
*.credentials.json